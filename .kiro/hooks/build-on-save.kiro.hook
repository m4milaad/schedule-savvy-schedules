{
  "enabled": true,
  "name": "Build on Save",
  "description": "Runs npm run build after every file edit to verify changes compile successfully",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "src/**/*.tsx",
      "src/**/*.ts"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npm run build",
    "timeout": 120
  }
}