DEMO_MODE=false
MODEL_BACKEND=tinyllama
# Use OpenRouter for /chat (set OPENROUTER_API_KEY). Example free model:
# MODEL_BACKEND=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free
# OPENROUTER_SITE_URL=https://your-app.example
# OPENROUTER_SITE_NAME=Schedule Savvy
# OPENROUTER_TIMEOUT_SECONDS=60
OLLAMA_URL=http://localhost:11434
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600
MAX_TOKENS=300
CONFIDENCE_THRESHOLD=0.35
RAG_STORE=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
CORS_ORIGINS=https://your-app-domain.com,https://your-space.hf.space
